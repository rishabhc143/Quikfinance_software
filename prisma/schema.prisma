  title          String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])
  messages       AiMessage[]

  @@index([organizationId, userId])
}

model AiMessage {
  id             String         @id @default(cuid())
  conversationId String
  role           String
  content        String         @db.Text
  createdAt      DateTime       @default(now())
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

// ───────────────────────── PHASE-X COMPLETION ─────────────────────────

model Reminder {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  appliesTo      String // "invoice" | "bill" | "estimate"
  daysBefore     Int          @default(0)
  daysAfter      Int          @default(0)
  template       String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, isActive])
}

model WorkflowAction {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  kind           String // "email" | "webhook" | "field-update" | "create-task"
  config         Json?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model WorkflowLog {
  id             String       @id @default(cuid())
  organizationId String
  ruleId         String?
  ruleName       String
  status         String // "success" | "failed" | "skipped"
  message        String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

model Schedule {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  cron           String
  taskKind       String
  isActive       Boolean      @default(true)
  lastRunAt      DateTime?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model ReportingTag {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  color          String       @default("#1d4ed8")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// ACCT-A.3.b.2 — direct join to per-line Reporting Tag use on
  /// Manual Journals + the canonical ledger. The legacy
  /// ContactReportingTag / QuoteReportingTag pattern routes through
  /// a (deferred) options layer; we go direct here so deletes
  /// cascade cleanly and the FK is real.
  manualJournalLineLinks ManualJournalLineReportingTag[]
  journalEntryLineLinks  JournalEntryLineReportingTag[]

  @@unique([organizationId, name])
}

model ManualJournalLineReportingTag {
  id                  String            @id @default(cuid())
  manualJournalLineId String
  reportingTagId      String
  manualJournalLine   ManualJournalLine @relation(fields: [manualJournalLineId], references: [id], onDelete: Cascade)
  reportingTag        ReportingTag      @relation(fields: [reportingTagId], references: [id], onDelete: Cascade)

  @@unique([manualJournalLineId, reportingTagId], name: "MJLRT_line_tag_unique")
  @@index([reportingTagId])
}

model JournalEntryLineReportingTag {
  id                 String           @id @default(cuid())
  journalEntryLineId String
  reportingTagId     String
  journalEntryLine   JournalEntryLine @relation(fields: [journalEntryLineId], references: [id], onDelete: Cascade)
  reportingTag       ReportingTag     @relation(fields: [reportingTagId], references: [id], onDelete: Cascade)

  @@unique([journalEntryLineId, reportingTagId], name: "JELRT_line_tag_unique")
  @@index([reportingTagId])
}

model WebTab {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  url            String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model CustomRole {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  description    String?
  permissions    Json // ["items.read", "items.write", ...]
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
}

model Integration {
  id             String       @id @default(cuid())
  organizationId String
  kind           String // "whatsapp" | "sms" | "bharat-connect" | "uber" | "zapier" | "razorpay" | ...
  isConnected    Boolean      @default(false)
  config         Json?
  connectedAt    DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, kind])
}

model WebForm {
  id               String       @id @default(cuid())
  organizationId   String
  name             String
  slug             String       @unique
  formConfig       Json?
  isActive         Boolean      @default(true)
  submissionsCount Int          @default(0)
  createdAt        DateTime     @default(now())
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model ApiUsageLog {
  id             String       @id @default(cuid())
  organizationId String
  endpoint       String
  method         String
  statusCode     Int
  durationMs     Int
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

// ─── M17a: Invoices Refinement Patch — additive only ─────────────────────

// Razorpay configuration per organization. Secrets are AES-256-GCM
// encrypted at rest via lib/crypto.ts (RAZORPAY_KEK env var).
model PaymentGatewayConfig {
  id                             String    @id @default(cuid())
  organizationId                 String    @unique
  razorpayEnabled                Boolean   @default(false)
  razorpayKeyId                  String?
  razorpayKeySecretEncrypted     String?
  razorpayWebhookSecretEncrypted String?
  razorpayMode                   String    @default("test") // test | live
  razorpayActivatedAt            DateTime?
  cardVerificationEnabled        Boolean   @default(false)
  createdAt                      DateTime  @default(now())
  updatedAt                      DateTime  @default(now()) @updatedAt
}

// Lifecycle log for Razorpay orders/payments. Idempotent on
// razorpayPaymentId — duplicate webhook events are safe to receive.
model RazorpayPaymentAttempt {
  id                String   @id @default(cuid())
  organizationId    String
  invoiceId         String
  razorpayOrderId   String   @unique
  razorpayPaymentId String?  @unique
  amount            Decimal  @db.Decimal(18, 4)
  currency          String
  status            String   @default("CREATED") // CREATED | ATTEMPTED | CAPTURED | FAILED
  failureReason     String?
  webhookPayload    Json?
  signatureVerified Boolean  @default(false)
  paymentReceivedId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt

  @@index([organizationId, invoiceId])
}

// Saved views per (org × module). System views (isSystem=true) are
// read-only; user views set userId. orgRecord.userId=null means a
// shared view (Phase S8+).
model SavedView {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  module         String // invoices | quotes | sales_orders | customers | …
  name           String
  filterJson     Json
  isSystem       Boolean  @default(false)
  isDefault      Boolean  @default(false)
  position       Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@index([organizationId, module, userId])
}

// Custom field definitions per (org × entityType). Generalized — same
// pattern reused later for Quote/SalesOrder/Customer custom fields.
model CustomFieldDefinition {
  id             String             @id @default(cuid())
  organizationId String
  entityType     String // INVOICE | QUOTE | SALES_ORDER | …
  fieldKey       String
  label          String
  dataType       String // text | number | date | dropdown | checkbox | email | url
  options        Json? // dropdown { label, value }[]
  isRequired     Boolean            @default(false)
  showOnPdf      Boolean            @default(false)
  showOnPortal   Boolean            @default(false)
  position       Int                @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @default(now()) @updatedAt
  deletedAt      DateTime?
  values         CustomFieldValue[]

  @@unique([organizationId, entityType, fieldKey])
}

// Field values keyed by (entityType, entityId, fieldDefinitionId).
// value is Json so any data type fits one column.
model CustomFieldValue {
  id                String                @id @default(cuid())
  organizationId    String
  entityType        String
  entityId          String
  fieldDefinitionId String
  value             Json
  fieldDefinition   CustomFieldDefinition @relation(fields: [fieldDefinitionId], references: [id], onDelete: Cascade)

  @@unique([entityType, entityId, fieldDefinitionId])
  @@index([organizationId, entityType, entityId])
}

// Per-user-per-org preferences. Reused by the dismissible "Want to get
// paid faster?" banner and other in-product flags.
model UserPreference {
  id             String  @id @default(cuid())
  userId         String
  organizationId String?
  key            String
  value          String

  @@unique([userId, organizationId, key])
}

// Customer-facing Debit Note (seller-issued). Increases the customer's
// receivable — Indian accounting convention. Distinct from CreditNote.
// Schema scaffolded; full UI is a follow-up.
model DebitNote {
  id                 String              @id @default(cuid())
  organizationId     String
  contactId          String
  debitNoteNumber    String // app-side: same shape as CreditNote.number
  referenceNumber    String?
  debitNoteDate      DateTime
  reason             String?
  status             String              @default("OPEN") // OPEN | CLOSED | VOID
  currency           String              @default("INR")
  subTotal           Decimal             @default(0) @db.Decimal(18, 4)
  taxAmount          Decimal             @default(0) @db.Decimal(18, 4)
  total              Decimal             @default(0) @db.Decimal(18, 4)
  amountApplied      Decimal             @default(0) @db.Decimal(18, 4)
  customerNotes      String?
  termsAndConditions String?
  pdfTemplateId      String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @default(now()) @updatedAt
  deletedAt          DateTime?
  contact            Contact             @relation(fields: [contactId], references: [id])
  lineItems          DebitNoteLineItem[]

  @@unique([organizationId, debitNoteNumber])
  @@index([organizationId, status, deletedAt])
}

model DebitNoteLineItem {
  id           String    @id @default(cuid())
  debitNoteId  String
  itemId       String?
  accountId    String?
  position     Int       @default(0)
  name         String
  description  String?
  hsnSacCode   String?
  quantity     Decimal   @db.Decimal(18, 4)
  unit         String?
  rate         Decimal   @db.Decimal(18, 4)
  discount     Decimal   @default(0) @db.Decimal(18, 4)
  discountType String    @default("percentage")
  taxId        String?
  taxAmount    Decimal   @default(0) @db.Decimal(18, 4)
  amount       Decimal   @db.Decimal(18, 4)
  debitNote    DebitNote @relation(fields: [debitNoteId], references: [id], onDelete: Cascade)

  @@index([debitNoteId])
}
