model Bill {
  id             String                  @id @default(cuid())
  organizationId String
  number         String
  contactId      String
  status         BillStatus              @default(DRAFT)
  issueDate      DateTime
  dueDate        DateTime
  subtotal       Decimal                 @default(0) @db.Decimal(18, 4)
  taxTotal       Decimal                 @default(0) @db.Decimal(18, 4)
  total          Decimal                 @default(0) @db.Decimal(18, 4)
  amountPaid     Decimal                 @default(0) @db.Decimal(18, 4)
  currency       String?
  exchangeRate   Decimal?                @db.Decimal(18, 6)
  notes          String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  deletedAt      DateTime?
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact        Contact                 @relation(fields: [contactId], references: [id])
  lineItems      BillLineItem[]
  payments       PaymentMadeAllocation[]

  @@unique([organizationId, number])
  @@index([organizationId, status, deletedAt])
}

enum BillStatus {
  DRAFT
  OPEN
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
}

model BillLineItem {
