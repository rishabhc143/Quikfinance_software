model PaymentMade {
  id                   String                  @id @default(cuid())
  organizationId       String
  number               String
  // BILL_PAYMENT (default) or VENDOR_ADVANCE. The Payments Made
  // form has two tabs that write the same table with a different
  // paymentType. Vendor advance balances are derived from
  // VENDOR_ADVANCE rows minus draws against them.
  paymentType          PaymentMadeType         @default(BILL_PAYMENT)
  contactId            String
  paymentDate          DateTime
  amount               Decimal                 @db.Decimal(18, 4)
  amountUsedForBills   Decimal                 @default(0) @db.Decimal(18, 4)
  amountInExcess       Decimal                 @default(0) @db.Decimal(18, 4)
  amountRefunded       Decimal                 @default(0) @db.Decimal(18, 4)
  tdsId                String?
  tdsAmount            Decimal?                @db.Decimal(18, 4)
  method               String?
  paymentMode          String? // alias used by new UI: cash, bank_transfer, cheque, etc
  reference            String?
  bankAccountId        String?
  paidThroughAccountId String?
  depositToAccountId   String? // Vendor Advance: where the advance sits
  status               String                  @default("DRAFT")
  notes                String?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @default(now()) @updatedAt
  deletedAt            DateTime?
  organization         Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact              Contact                 @relation(fields: [contactId], references: [id])
  allocations          PaymentMadeAllocation[]

  @@unique([organizationId, number])
  @@index([organizationId, paymentType, status])
