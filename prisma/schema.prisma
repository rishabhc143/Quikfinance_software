// ───────────────────────── PURCHASES ─────────────────────────

model Bill {
  id                 String                    @id @default(cuid())
  organizationId     String
  // `number` keeps its old name for back-compat — UI label is "Bill#".
  // Spec: manually entered by user from the vendor's source doc.
  number             String
  referenceNumber    String? // shown as "Order Number" in the UI
  contactId          String
  status             BillStatus                @default(DRAFT)
  issueDate          DateTime
  dueDate            DateTime
  paymentTermsId     String?
  subject            String?
  subtotal           Decimal                   @default(0) @db.Decimal(18, 4)
  discountValue      Decimal                   @default(0) @db.Decimal(18, 4)
  discountType       String                    @default("percentage")
  taxId              String?
  taxTotal           Decimal                   @default(0) @db.Decimal(18, 4)
  adjustmentLabel    String?                   @default("Adjustment")
  adjustmentValue    Decimal                   @default(0) @db.Decimal(18, 4)
  total              Decimal                   @default(0) @db.Decimal(18, 4)
  amountPaid         Decimal                   @default(0) @db.Decimal(18, 4)
  currency           String?
  exchangeRate       Decimal?                  @db.Decimal(18, 6)
  notes              String?
  termsAndConditions String?
  placeOfSupply      String?
  accountsPayableId  String?
  purchaseOrderId    String?
  recurringBillId    String?
  pdfTemplateId      String?
  portalAccessToken  String                    @unique @default(cuid())
  voidedAt           DateTime?
  writtenOffAt       DateTime?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  deletedAt          DateTime?
  organization       Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact            Contact                   @relation(fields: [contactId], references: [id])
  purchaseOrder      PurchaseOrder?            @relation(fields: [purchaseOrderId], references: [id])
  recurringBill      RecurringBill?            @relation("RecurringBillGenerated", fields: [recurringBillId], references: [id])
  lineItems          BillLineItem[]
  payments           PaymentMadeAllocation[]
  creditApplications VendorCreditApplication[]
  attachments        BillAttachment[]

  // Per spec: bill numbers are MANUAL from the vendor's source doc.
  // Duplicates per (org, vendor, number) are FLAGGED WITH WARNING but
  // ALLOWED — vendors sometimes reuse their own numbers across
  // restatements. The non-unique index keeps the warning query fast.
  @@index([organizationId, contactId, number])
  @@index([organizationId, status, deletedAt])
}

enum BillStatus {
  DRAFT
  OPEN
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
  WRITTEN_OFF
}

model BillLineItem {
  id                   String    @id @default(cuid())
  billId               String
  itemId               String?
  position             Int       @default(0)
  name                 String    @default("")
  description          String
  hsnSacCode           String?
  accountId            String? // inline column on the Bill form
  quantity             Decimal   @db.Decimal(18, 4)
  rate                 Decimal   @db.Decimal(18, 4)
  taxId                String?
  amount               Decimal   @db.Decimal(18, 4)
  // Billable-expense tracking: when set, this line is owed back from
  // a specific customer and can be added to their next invoice.
  billableToCustomerId String?
  billableUsedAt       DateTime?
  bill                 Bill      @relation(fields: [billId], references: [id], onDelete: Cascade)
  item                 Item?     @relation(fields: [itemId], references: [id])

  @@index([billableToCustomerId, billableUsedAt])
}

