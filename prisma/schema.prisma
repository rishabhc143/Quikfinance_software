  generatedExpenses    Expense[]    @relation("RecurringExpenseGenerated")
}

model BillableExpenseUsage {
  id                String   @id @default(cuid())
  organizationId    String
  sourceType        String // BILL_LINE_ITEM | EXPENSE
  sourceId          String
  customerId        String
  invoiceLineItemId String?
  amount            Decimal  @db.Decimal(18, 4)
  usedAt            DateTime @default(now())

  @@unique([sourceType, sourceId])
  @@index([organizationId, customerId])
}

model BankIntegration {
  id                String   @id @default(cuid())
  organizationId    String   @unique
  bankPartner       String?
  isConfigured      Boolean  @default(false)
  configurationJson Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt
}

// ───────────────────────── BANKING ─────────────────────────

model BankAccount {
  id             String             @id @default(cuid())
  organizationId String
  name           String
  accountNumber  String?
  /// Legacy free-text type ("checking" / "savings" / "credit_card" / "cash" /
  /// "wallet"). New code reads `type` (the BankAccountType enum below) instead.
  /// Kept for backward compat — drop in a future cleanup PR.
  accountType    String             @default("checking")
  /// BNK-A — Zoho-parity account kind. Maps to the radio in the Add Bank or
  /// Credit Card form. Existing rows were back-filled from `accountType`:
  /// credit_card → CREDIT_CARD, wallet → PAYPAL, everything else → BANK.
  type           BankAccountType    @default(BANK)
  /// Only one BANK can be primary per org (partial unique index enforced
  /// at the DB level).
  isPrimary      Boolean            @default(false)
  bankName       String?
  ifsc           String?
  description    String?
  currency       String             @default("INR")
  openingBalance Decimal            @default(0) @db.Decimal(18, 4)
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  /// BNK-D — Bridge to ChartOfAccount so Money In Categorise can post a
  /// balanced 2-line JournalEntry. Lazily created by
  /// getOrCreateBankGLAccount() on first need; existing rows stay null
  /// until they're categorised against.
  glAccountId    String?
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  glAccount      ChartOfAccount?    @relation("BankAccountGL", fields: [glAccountId], references: [id], onDelete: SetNull)
  transactions   BankTransaction[]
  importBatches  BankImportBatch[]
  importPresets  BankImportPreset[]
  /// BNK-E — rules scoped to this specific bank account.
  rules          BankRule[]
  /// BNK-F — reconciliations on this account.
  reconciliations Reconciliation[]
}

enum BankAccountType {
  BANK
  CREDIT_CARD
  PAYPAL
}

model BankTransaction {
  id             String           @id @default(cuid())
  organizationId String
  bankAccountId  String
  date           DateTime
  description    String?
  reference      String?
  amount         Decimal          @db.Decimal(18, 4)
  type           String
  isReconciled   Boolean          @default(false)
  /// BNK-A — set to true when the CSV import detected this row as a duplicate
  /// of an existing transaction. The row is still persisted (so undo works)
  /// but is hidden from default views.
  excluded       Boolean          @default(false)
  excludedReason String?
  /// Links the row to the import batch that created it. Null for manually-
  /// entered transactions. Used by the "Undo Last Import" action.
  importBatchId  String?
  /// BNK-C — single-record match. When the user matches this bank line to an
  /// existing Invoice / Bill / PaymentReceived / PaymentMade / Expense, we
  /// store the (type, id) pair here. Cleared via Unmatch action. BNK-D will
  /// introduce a join table for multi-match scenarios.
  matchedRecordType String?
  matchedRecordId   String?
  matchedAt         DateTime?
  matchedById       String?
  /// BNK-D — true when Categorise auto-created the linked record
  /// (Expense for Money Out, JournalEntry for Money In). Unmatch then
  /// also deletes the linked record so the books don't accumulate
  /// orphan entries. False for records the user matched manually
  /// (preserves original BNK-C unmatch semantics).
  matchAutoCreated  Boolean          @default(false)
  /// BNK-E — which rule fired on import. Nullable: manual matches and
  /// rule-less imports leave this empty.
  appliedRuleId     String?
  /// BNK-F — which reconciliation cleared this row. The existing
  /// `isReconciled` boolean stays; this back-pointer tells you which
  /// run it belongs to (so Undo can find them all).
  reconciliationId  String?
  reconciledAt      DateTime?
  createdAt      DateTime         @default(now())
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bankAccount    BankAccount      @relation(fields: [bankAccountId], references: [id])
  importBatch    BankImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  matchedBy      User?            @relation("BankTransactionMatchedBy", fields: [matchedById], references: [id], onDelete: SetNull)
  appliedRule    BankRule?        @relation(fields: [appliedRuleId], references: [id], onDelete: SetNull)
  reconciliation Reconciliation?  @relation(fields: [reconciliationId], references: [id], onDelete: SetNull)

  @@index([organizationId, date])
  @@index([bankAccountId, date, amount, reference], name: "BankTransaction_dedup_idx")
}

/// BNK-A — one row per CSV upload. Lets "Undo Last Import" find every row
/// the batch created. Cascade-deletes its transactions when the user undoes.
model BankImportBatch {
  id              String            @id @default(cuid())
  organizationId  String
  bankAccountId   String
  uploadedById    String
  fileName        String
  rowCount        Int
  duplicateCount  Int               @default(0)
  createdAt       DateTime          @default(now())
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bankAccount     BankAccount       @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  uploadedBy      User              @relation(fields: [uploadedById], references: [id], onDelete: Restrict)
  transactions    BankTransaction[]

  @@index([bankAccountId, createdAt(sort: Desc)], name: "BankImportBatch_account_created_idx")
}

/// BNK-A — saved column-mapping presets. After a successful import, the user
/// can save the mapping under a name (e.g. "ICICI monthly statement") and
/// reuse it for next month's import without re-mapping every column.
model BankImportPreset {
  id               String       @id @default(cuid())
  organizationId   String
  bankAccountId    String
  name             String
  amountColumnType String       // 'DOUBLE' | 'SINGLE_WITH_TYPE' | 'SINGLE_NEGATIVE'
  encoding         String       @default("utf-8")
  delimiter        String       @default(",")
  columnMapJson    Json
  createdAt        DateTime     @default(now())
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bankAccount      BankAccount  @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@unique([bankAccountId, name], name: "BankImportPreset_account_name_unique")
}

/// BNK-E — Transaction rule. IF (conditions joined by combinator)
/// THEN Categorise to actionGlAccountId.
///
/// Conditions live as JSONB so the operator vocabulary can grow
/// without schema churn — each entry is { field, op, value }.
/// Combinator is "AND" or "OR" (v1 supports both; UI exposes AND only).
///
/// Per-account rules (bankAccountId not null) beat org-wide rules
/// (null) when both match. Within the same scope, lower priority
/// wins. First-match-wins — the engine stops at the first hit.
model BankRule {
  id                String           @id @default(cuid())
  organizationId    String
  bankAccountId     String?
  name              String
  priority          Int              @default(100)
  isActive          Boolean          @default(true)
  conditionsJson    Json
  combinator        String           @default("AND")
  actionGlAccountId String
  actionNotes       String?
  /// Counter bumped each time the rule fires on import. Cheap stat;
  /// the rules list shows "Fired 47×" so users can spot dead rules.
  timesFired        Int              @default(0)
  lastFiredAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @default(now()) @updatedAt
  organization      Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bankAccount       BankAccount?     @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  actionGlAccount   ChartOfAccount   @relation("BankRuleActionGL", fields: [actionGlAccountId], references: [id], onDelete: Restrict)
  appliedTo         BankTransaction[]

  @@index([organizationId, bankAccountId, priority], name: "BankRule_org_account_priority_idx")
}

/// BNK-F — Reconciliation header. One row per (account, period). Status
/// flips IN_PROGRESS → FINALISED on Finish, or → UNDONE on Undo. The
/// cleared transactions point back here via BankTransaction.reconciliationId.
///
/// Opening balance is carried forward from the previous FINALISED
/// reconciliation's closing balance (or BankAccount.openingBalance for
/// the first). Closing balance is what the user typed in from the
/// statement. The math holds when:
///
///   openingBalance + Σ(cleared CREDIT) − Σ(cleared DEBIT) = closingBalance
///
/// — i.e. Difference = 0. Finalise refuses unless this is true.
model Reconciliation {
  id             String            @id @default(cuid())
  organizationId String
  bankAccountId  String
  startDate      DateTime          @db.Date
  endDate        DateTime          @db.Date
  openingBalance Decimal           @db.Decimal(18, 4)
  closingBalance Decimal           @db.Decimal(18, 4)
  /// IN_PROGRESS | FINALISED | UNDONE
  status         String            @default("IN_PROGRESS")
  notes          String?
  createdAt      DateTime          @default(now())
  createdById    String
  finalisedAt    DateTime?
  finalisedById  String?
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bankAccount    BankAccount       @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  createdBy      User              @relation("ReconciliationCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  finalisedBy    User?             @relation("ReconciliationFinalisedBy", fields: [finalisedById], references: [id], onDelete: SetNull)
  transactions   BankTransaction[]

  @@index([bankAccountId, createdAt(sort: Desc)], name: "Reconciliation_account_created_idx")
}

// ───────────────────────── ACCOUNTANT ─────────────────────────

model JournalEntry {
  id             String             @id @default(cuid())
  organizationId String
  date           DateTime
  reference      String?
  notes          String?
  createdAt      DateTime           @default(now())
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lines          JournalEntryLine[]
}

model JournalEntryLine {
  id             String         @id @default(cuid())
  journalEntryId String
  accountId      String
  debit          Decimal        @default(0) @db.Decimal(18, 4)
  credit         Decimal        @default(0) @db.Decimal(18, 4)
  description    String?
  /// ACCT-A.3.b — per-line dimensions. Carried through from
  /// ManualJournalLine at publish time so reports can group by
  /// contact / project at the ledger level.
  contactId      String?
  projectId      String?
  journalEntry   JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  /// RPT-A — declared so the Trial Balance + P&L reports can `include`
  /// the CoA entry without a separate query. FK added by migration
  /// 20260513000006.
  account        ChartOfAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)
  contact        Contact?       @relation("JournalEntryLineContact", fields: [contactId], references: [id], onDelete: SetNull)
  project        Project?       @relation("JournalEntryLineProject", fields: [projectId], references: [id], onDelete: SetNull)
  /// ACCT-A.3.b.2 — many-to-many to ReportingTag via a join table.
  reportingTagLinks JournalEntryLineReportingTag[]

  @@index([contactId])
  @@index([projectId])
}

model ManualJournal {
  id             String       @id @default(cuid())
  organizationId String
  number         String
  date           DateTime
  notes          String?
  /// ACCT-A.2 — Zoho-parity header fields.
  /// Free-text external reference (e.g. an attached doc id).
  referenceNumber          String?
  /// DRAFT | PUBLISHED. Existing rows default to PUBLISHED (they
  /// posted JEs pre-PR).
  status                   String   @default("PUBLISHED")
  /// ACCRUAL_AND_CASH | ACCRUAL_ONLY | CASH_ONLY. For v1 stored only;
  /// reports continue to read accrual data from the ledger.
  reportingMethod          String   @default("ACCRUAL_AND_CASH")
  /// Three-letter ISO code; defaults to org currency on the client.
  currency                 String?
  /// When set, a reversing JE is auto-posted on this date with
  /// reference MJ-REV:<id> and DR/CR flipped.
  reverseJournalDate       DateTime? @db.Date
  /// Zoho-parity flag — stored for round-trip fidelity. For v1 the
  /// reverse JE is always date-stamped to reverseJournalDate; the
  /// checkbox is a no-op functionally.
  publishReverseOnlyOnDate Boolean  @default(false)
  /// ACCT-A.4.c — when set, this MJ was auto-generated by a
  /// RecurringManualJournal profile. Doubles as the date-bucket
  /// idempotency key so the cron can skip re-generation.
  recurringManualJournalId String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// ACCT-A.3 — line storage. Source of truth for DRAFT lines and
  /// the edit form. PUBLISHED journals also have a copy in
  /// JournalEntryLine (under reference MJ:<id>) for the canonical
  /// ledger query path.
  lines          ManualJournalLine[]
  recurringManualJournal RecurringManualJournal? @relation(fields: [recurringManualJournalId], references: [id], onDelete: SetNull)
  /// ACCT-A.3.c — Up to 5 × 10 MB files per journal. Cascades on
  /// delete so attachments don't outlive their parent header.
  attachments    ManualJournalAttachment[]

  @@unique([organizationId, number])
  @@index([organizationId, status], name: "ManualJournal_org_status_idx")
  @@index([recurringManualJournalId])
}

/// ACCT-C — Currency Adjustment header. Each adjustment posts a
/// JE under reference `CADJ:<id>` with lines that offset against
/// SYS-FX-GAIN or SYS-FX-LOSS. v1 is manual entry; auto-balance
/// computation from per-line FC amounts ships in ACCT-C.2.
model CurrencyAdjustment {
  id             String       @id @default(cuid())
  organizationId String
  number         String
  date           DateTime     @db.Date
  /// 3-letter ISO; the foreign currency being revalued.
  currency       String
  /// Optional, informational — the rate the accountant cited when
  /// computing the adjustment. The ledger gets the absolute
  /// gain/loss amounts in org-default currency, not a rate.
  exchangeRate   Decimal?     @db.Decimal(18, 6)
  notes          String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, number])
  @@index([organizationId, date])
}

/// ACCT-A.3.c — Mirrors CreditNoteAttachment. Data-URL based for
/// v1; switches to real blob storage when /api/upload graduates
/// from its dev stub.
model ManualJournalAttachment {
  id              String        @id @default(cuid())
  manualJournalId String
  fileName        String
  fileUrl         String        @db.Text
  fileSize        Int
  mimeType        String
  createdAt       DateTime      @default(now())
  manualJournal   ManualJournal @relation(fields: [manualJournalId], references: [id], onDelete: Cascade)

  @@index([manualJournalId])
}

/// ACCT-A.4.c — "Make Recurring" profile for Manual Journals.
/// Mirrors the RecurringBill shape: cron polls daily, generates
/// a DRAFT ManualJournal at each occurrence, advances the cursor.
/// Idempotency via the `recurringManualJournalId` back-ref on
/// generated MJs (we check for a same-day MJ before generating).
model RecurringManualJournal {
  id                   String       @id @default(cuid())
  organizationId       String
  profileName          String
  frequency            String       // "daily" | "weekly" | "monthly" | "quarterly" | "yearly"
  intervalN            Int          @default(1)
  startDate            DateTime
  endDate              DateTime?
  neverExpires         Boolean      @default(false)
  /// When the next MJ should be generated. Advanced by the cron.
  nextOccurrenceDate   DateTime
  /// ACTIVE | PAUSED | STOPPED | EXPIRED — mirrors RecurringBill.
  status               String       @default("ACTIVE")
  isActive             Boolean      @default(true)
  occurrencesGenerated Int          @default(0)
  /// Serialized header + lines snapshot used to materialise each
  /// occurrence. Shape lives in lib/accounting/recurring-manual-journals.ts.
  templateJson         Json?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @default(now()) @updatedAt
  deletedAt            DateTime?
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  generatedJournals    ManualJournal[]

  @@index([organizationId, status, nextOccurrenceDate])
  @@index([deletedAt])
}

model ManualJournalLine {
  id              String         @id @default(cuid())
  manualJournalId String
  position        Int            @default(0)
  accountId       String
  debit           Decimal        @default(0) @db.Decimal(18, 4)
  credit          Decimal        @default(0) @db.Decimal(18, 4)
  description     String?
  /// ACCT-A.3.b — per-line dimensions. Optional; copied verbatim into
  /// the canonical JournalEntryLine rows at publish time.
  contactId       String?
  projectId       String?
  manualJournal   ManualJournal  @relation(fields: [manualJournalId], references: [id], onDelete: Cascade)
  account         ChartOfAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)
  contact         Contact?       @relation("ManualJournalLineContact", fields: [contactId], references: [id], onDelete: SetNull)
  project         Project?       @relation("ManualJournalLineProject", fields: [projectId], references: [id], onDelete: SetNull)
  /// ACCT-A.3.b.2 — many-to-many to ReportingTag via a join table.
  reportingTagLinks ManualJournalLineReportingTag[]

  @@index([manualJournalId])
  @@index([contactId])
  @@index([projectId])
}

