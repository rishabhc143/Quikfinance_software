// Quikfinance schema — covers every module up front so future migrations are additive.
// Money is Decimal(18,4). Multi-tenant: every business table has organizationId.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ───────────────────────── AUTH (NextAuth Prisma adapter) ─────────────────────────

model User {
  id                  String                   @id @default(cuid())
  email               String                   @unique
  emailVerified       DateTime?
  name                String?
  image               String?
  passwordHash        String?
  referralCode        String?                  @unique
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  memberships         OrganizationMembership[]
  sessions            Session[]
  accounts            Account[]
  auditLogs           AuditLog[]
  passwordResetTokens PasswordResetToken[]
  verificationTokens  EmailVerificationToken[]
  referralsMade       Referral[]               @relation("Referrer")
  aiConversations     AiConversation[]
  bankImportBatches   BankImportBatch[]
  bankTxnsMatched     BankTransaction[]        @relation("BankTransactionMatchedBy")
  reconciliationsCreated   Reconciliation[]    @relation("ReconciliationCreatedBy")
  reconciliationsFinalised Reconciliation[]    @relation("ReconciliationFinalisedBy")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model EmailVerificationToken {
  id      String   @id @default(cuid())
  userId  String
  token   String   @unique
  expires DateTime
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  userId  String
  token   String   @unique
  expires DateTime
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ───────────────────────── ORGANIZATIONS ─────────────────────────

model Organization {
  id                    String                   @id @default(cuid())
  name                  String
  slug                  String                   @unique
  currency              String                   @default("INR")
  country               String                   @default("IN")
  fiscalYearStart       Int                      @default(4)
  gstin                 String? // Supplier GSTIN, used by GSTR-1 export
  logoUrl               String?
  planTier              String                   @default("trial")
  trialEndsAt           DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  members               OrganizationMembership[]
  items                 Item[]
  contacts              Contact[]
  invoices              Invoice[]
  bills                 Bill[]
  quotes                Quote[]
  salesOrders           SalesOrder[]
  deliveryChallans      DeliveryChallan[]
  recurringInvoices     RecurringInvoice[]
  creditNotes           CreditNote[]
  paymentsReceived      PaymentReceived[]
  purchaseOrders        PurchaseOrder[]
  recurringBills        RecurringBill[]
  paymentsMade          PaymentMade[]
  vendorCredits         VendorCredit[]
  expenses              Expense[]
  recurringExpenses     RecurringExpense[]
  bankAccounts          BankAccount[]
  bankTransactions      BankTransaction[]
  bankImportBatches     BankImportBatch[]
  bankImportPresets     BankImportPreset[]
  bankRules             BankRule[]
  reconciliations       Reconciliation[]
  journalEntries        JournalEntry[]
  manualJournals        ManualJournal[]
  recurringManualJournals RecurringManualJournal[]
  currencyAdjustments   CurrencyAdjustment[]
  chartOfAccounts       ChartOfAccount[]
  taxes                 Tax[]
  projects              Project[]
  tasks                 Task[]
  timeEntries           TimeEntry[]
  documents             Document[]
  auditLogs             AuditLog[]
  notifications         Notification[]
  apiKeys               ApiKey[]
  webhooks              Webhook[]
  workflowRules         WorkflowRule[]
  numberSeries          NumberSeries[]
  preferences           OrganizationPreference?
  locations             Location[]
  promoBanners          PromoBanner[]
  aiConversations       AiConversation[]
  reminders             Reminder[]
  workflowActions       WorkflowAction[]
  workflowLogs          WorkflowLog[]
  schedules             Schedule[]
  reportingTags         ReportingTag[]
  webTabs               WebTab[]
  customRoles           CustomRole[]
  integrations          Integration[]
  webForms              WebForm[]
  apiUsageLogs          ApiUsageLog[]
  inventoryAdjustments  InventoryAdjustment[]
  inventoryReservations InventoryReservation[]
  paymentTerms          PaymentTerms[]
  deliveryMethods       DeliveryMethod[]
  salespeople           Salesperson[]
  pdfTemplates          PdfTemplate[]
  emailJobs             EmailJob[]
}

model OrganizationMembership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           Role         @default(STAFF)
  isDefault      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

enum Role {
  ADMIN
  STAFF
  ACCOUNTANT
  VIEWER
}

model OrganizationPreference {
  id                      String       @id @default(cuid())
  organizationId          String       @unique
  inventoryEnabled        Boolean      @default(false)
  decimalFormat           String       @default("1,234,567.89")
  dateFormat              String       @default("dd/MM/yyyy")
  timeZone                String       @default("Asia/Kolkata")
  brandColor              String       @default("#1d4ed8")
  language                String       @default("en")
  emailOnInvoiceSent      Boolean      @default(true)
  emailOnInvoicePaid      Boolean      @default(true)
  emailOnBillDue          Boolean      @default(true)
  emailOnPaymentReceived  Boolean      @default(true)
  emailOnEstimateAccepted Boolean      @default(false)
  emailDigestWeekly       Boolean      @default(false)
  customDomain            String?
  msmeRegistered          Boolean      @default(false)
  msmeNumber              String?
  tdsEnabled              Boolean      @default(false)
  tanNumber               String?
  panNumber               String?
  customerPortalEnabled   Boolean      @default(false)
  vendorPortalEnabled     Boolean      @default(false)
  aiSystemPromptOverride  String?
  aiRateLimitPerDay       Int          @default(50)
  pdfTemplate             String       @default("default")
  smsEnabled              Boolean      @default(false)
  digitalSignatureEnabled Boolean      @default(false)
  themeDefault            String       @default("system")
  densityDefault          String       @default("comfortable")
  salesPreferences        Json?
  organization            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Location {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  address        String?
  isPrimary      Boolean      @default(false)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model PromoBanner {
  id             String       @id @default(cuid())
  organizationId String
  message        String
  ctaLabel       String?
  ctaUrl         String?
  dismissedAt    DateTime?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// ───────────────────────── CHART OF ACCOUNTS ─────────────────────────

model ChartOfAccount {
  id             String           @id @default(cuid())
  organizationId String
  code           String?
  name           String
  type           AccountType
  parentId       String?
  description    String?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  parent         ChartOfAccount?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children       ChartOfAccount[] @relation("AccountHierarchy")
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// BNK-D back-relation: bank accounts whose GL bridge points here.
  bankAccounts   BankAccount[]    @relation("BankAccountGL")
  /// BNK-E back-relation: rules whose Categorise action posts here.
  ruleActions    BankRule[]       @relation("BankRuleActionGL")
  /// RPT-A back-relation: JE lines posting to this account.
  journalEntryLines JournalEntryLine[]
  /// ACCT-A.3 back-relation: Manual Journal lines (DRAFT + PUBLISHED).
  manualJournalLines ManualJournalLine[]

  @@unique([organizationId, code])
  @@index([organizationId, type])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
  COST_OF_GOODS_SOLD
  OTHER_INCOME
  OTHER_EXPENSE
}

// ───────────────────────── CONTACTS ─────────────────────────

model Contact {
  id                   String                @id @default(cuid())
  organizationId       String
  type                 ContactType           @default(CUSTOMER)
  customerType         CustomerType          @default(BUSINESS)
  salutation           String?
  firstName            String?
  lastName             String?
  displayName          String
  companyName          String?
  email                String?
  phone                String? // legacy free-form, kept for back-compat
  workPhone            String?
  workPhoneCountry     String?               @default("+91")
  mobile               String?
  mobileCountry        String?               @default("+91")
  billingAddress       String? // legacy single-line, kept for back-compat
  shippingAddress      String? // legacy single-line, kept for back-compat
  taxId                String? // legacy generic; new GST/PAN fields below
  pan                  String?
  gstin                String?
  gstTreatment         String? // registered/unregistered/composition/...
  placeOfSupply        String?
  taxPreference        String? // taxable | tax_exempt
  language             String                @default("en")
  currency             String?
  accountsReceivableId String?
  accountsPayableId    String?
  openingBalance       Decimal?              @db.Decimal(18, 4)
  openingBalanceAsOf   DateTime?
  paymentTermsId       String?
  enablePortal         Boolean               @default(false)
  portalLanguage       String?
  customerOwnerId      String? // userId of assigned owner
  websiteUrl           String?
  facebookUrl          String?
  twitterHandle        String?
  isInactive           Boolean               @default(false)
  notes                String?
  // === Purchases-module additions ===
  // MSME registration (Indian compliance — surfaced as a banner on
  // the Vendors list when org.country='IN' AND any vendor's
  // msmeRegistered is still null).
  msmeRegistered       Boolean?
  msmeNumber           String?
  msmeCategory         String? // MICRO | SMALL | MEDIUM
  msmeRegisteredDate   DateTime?
  // Default TDS tax used when this vendor is selected on a Bill / PO
  defaultTdsId         String?
  // Vendor-portal scaffolding (no UI in v1)
  enableVendorPortal   Boolean               @default(false)
  vendorPortalToken    String?               @unique
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  deletedAt            DateTime?
  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  addresses            ContactAddress[]
  contactPersons       ContactPerson[]
  contactDocuments     ContactDocument[]
  reportingTagJoins    ContactReportingTag[]
  customFields         ContactCustomField[]
  remarks              ContactRemark[]
  invoices             Invoice[]
  bills                Bill[]
  quotes               Quote[]
  salesOrders          SalesOrder[]
  expenses             Expense[]
  preferredFor         Item[]                @relation("PreferredVendor")
  paymentsReceived     PaymentReceived[]
  paymentsMade         PaymentMade[]
  creditNotes          CreditNote[]
  debitNotes           DebitNote[]
  vendorCredits        VendorCredit[]
  purchaseOrders       PurchaseOrder[]
  deliveryChallans     DeliveryChallan[]
  recurringInvoices    RecurringInvoice[]
  recurringBills       RecurringBill[]
  recurringExpenses    RecurringExpense[]
  bankAccounts         ContactBankAccount[]
  /// ACCT-A.3.b — per-line dimensions on Manual Journals + the
  /// canonical ledger. Named relations so Prisma doesn't conflate
  /// the two back-refs.
  manualJournalLines   ManualJournalLine[] @relation("ManualJournalLineContact")
  journalEntryLines    JournalEntryLine[]  @relation("JournalEntryLineContact")

  @@index([organizationId, type, deletedAt])
  @@index([organizationId, displayName])
  @@index([organizationId, isInactive])
}

model ContactBankAccount {
  id                String   @id @default(cuid())
  contactId         String
  accountHolderName String?
  bankName          String?
  accountNumber     String
  ifscCode          String
  isDefault         Boolean  @default(false)
  position          Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  contact           Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
}

enum ContactType {
  CUSTOMER
  VENDOR
  BOTH
}

enum CustomerType {
  BUSINESS
  INDIVIDUAL
}

model ContactAddress {
  id           String  @id @default(cuid())
  contactId    String
  kind         String // billing | shipping | other
  attention    String?
  country      String  @default("India")
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  zipCode      String?
  phone        String?
  fax          String?
  isDefault    Boolean @default(false)
  contact      Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId, kind])
}

model ContactPerson {
  id          String  @id @default(cuid())
  contactId   String
  salutation  String?
  firstName   String?
  lastName    String?
  email       String?
  workPhone   String?
  mobile      String?
  designation String?
  department  String?
  isPrimary   Boolean @default(false)
  contact     Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
}

model ContactDocument {
  id           String   @id @default(cuid())
  contactId    String
  fileName     String
  fileUrl      String
  fileSize     Int
  mimeType     String
  uploadedById String?
  createdAt    DateTime @default(now())
  contact      Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
}

model ContactReportingTag {
  id                   String  @id @default(cuid())
  contactId            String
  reportingTagOptionId String // free-form id; ReportingTagOption table deferred
  contact              Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
}

model ContactCustomField {
  id        String  @id @default(cuid())
  contactId String
  fieldKey  String
  value     Json?
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, fieldKey])
}

model ContactRemark {
  id        String   @id @default(cuid())
  contactId String
  body      String
  authorId  String?
  createdAt DateTime @default(now())
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId, createdAt])
}

// ───────────────────────── ITEMS ─────────────────────────

model InventoryReservation {
  id             String       @id @default(cuid())
  organizationId String
  itemId         String
  quantity       Decimal      @db.Decimal(18, 4)
  sourceType     String // "SalesOrder" | "DeliveryChallan"
  sourceId       String
  sourceNumber   String // human-readable, for ledger UI
  reservedAt     DateTime     @default(now())
  releasedAt     DateTime? // null = active reservation
  consumedAt     DateTime? // set when DC ships
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  item           Item         @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([organizationId, itemId, releasedAt, consumedAt])
  @@index([sourceType, sourceId])
}

model Item {
  id                    String                  @id @default(cuid())
  organizationId        String
  name                  String
  sku                   String?
  type                  ItemType                @default(GOODS)
  unit                  String?
  sellingPrice          Decimal?                @db.Decimal(18, 4)
  salesAccountId        String?
  salesDescription      String?
  costPrice             Decimal?                @db.Decimal(18, 4)
  purchaseAccountId     String?
  purchaseDescription   String?
  preferredVendorId     String?
  imageUrl              String?
  images                String[]                @default([])
  trackInventory        Boolean                 @default(false)
  inventoryAccountId    String?
  openingStock          Decimal?                @db.Decimal(18, 4)
  openingStockRate      Decimal?                @db.Decimal(18, 4)
  reorderPoint          Decimal?                @db.Decimal(18, 4)
  isActive              Boolean                 @default(true)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  deletedAt             DateTime?
  organization          Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  preferredVendor       Contact?                @relation("PreferredVendor", fields: [preferredVendorId], references: [id])
  invoiceLineItems      InvoiceLineItem[]
  billLineItems         BillLineItem[]
  inventoryAdjustments  InventoryAdjustment[]
  inventoryReservations InventoryReservation[]
  PurchaseOrderLineItem PurchaseOrderLineItem[]
  VendorCreditLineItem  VendorCreditLineItem[]

  @@index([organizationId, deletedAt])
  @@index([organizationId, name])
  @@index([organizationId, isActive])
}

enum ItemType {
  GOODS
  SERVICE
}

model InventoryAdjustment {
  id             String       @id @default(cuid())
  organizationId String
  itemId         String
  date           DateTime
  quantity       Decimal      @db.Decimal(18, 4) // signed: positive = increase, negative = decrease
  reason         String
  notes          String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  item           Item         @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([organizationId, date])
  @@index([itemId])
}

// ───────────────────────── SALES ─────────────────────────

model Invoice {
  id                 String                      @id @default(cuid())
  organizationId     String
  number             String // app code refers to this as invoiceNumber
  referenceNumber    String?
  contactId          String
  status             InvoiceStatus               @default(DRAFT)
  issueDate          DateTime
  dueDate            DateTime
  paymentTermsId     String?
  salespersonId      String?
  projectId          String?
  subtotal           Decimal                     @default(0) @db.Decimal(18, 4)
  discountValue      Decimal                     @default(0) @db.Decimal(18, 4)
  discountType       String                      @default("percentage")
  taxType            String?
  taxId              String?
  taxTotal           Decimal                     @default(0) @db.Decimal(18, 4)
  adjustmentLabel    String?                     @default("Adjustment")
  adjustmentValue    Decimal                     @default(0) @db.Decimal(18, 4)
  total              Decimal                     @default(0) @db.Decimal(18, 4)
  amountPaid         Decimal                     @default(0) @db.Decimal(18, 4)
  currency           String?
  exchangeRate       Decimal?                    @db.Decimal(18, 6)
  isRetail           Boolean                     @default(false)
  notes              String?
  terms              String?
  customerNotes      String?
  termsAndConditions String?
  pdfTemplateId      String?
  recurringInvoiceId String?
  portalAccessToken  String                      @unique @default(cuid())
  sentAt             DateTime?
  voidedAt           DateTime?
  writtenOffAt       DateTime?
  writtenOffAmount   Decimal?                    @db.Decimal(18, 4)
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  deletedAt          DateTime?
  organization       Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact            Contact                     @relation(fields: [contactId], references: [id])
  recurringSource    RecurringInvoice?           @relation("RecurringGenerated", fields: [recurringInvoiceId], references: [id])
  lineItems          InvoiceLineItem[]
  payments           PaymentReceivedAllocation[]
  attachments        InvoiceAttachment[]
  reminders          InvoiceReminder[]
  creditApplications CreditNoteApplication[]

  @@unique([organizationId, number])
  @@index([organizationId, status, deletedAt])
  @@index([organizationId, isRetail])
  @@index([organizationId, contactId, status])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
  WRITTEN_OFF
}

model InvoiceAttachment {
  id        String   @id @default(cuid())
  invoiceId String
  fileName  String
  fileUrl   String
  fileSize  Int
  mimeType  String
  createdAt DateTime @default(now())
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model InvoiceReminder {
  id         String    @id @default(cuid())
  invoiceId  String
  type       String // BEFORE_DUE | AFTER_DUE | MANUAL
  daysOffset Int       @default(0)
  sentAt     DateTime?
  createdAt  DateTime  @default(now())
  invoice    Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  itemId      String?
  accountId   String? // M17a — per-line override of item's default income account
  description String
  hsnSacCode  String? // Per-line HSN/SAC; used by GSTR-1 export
  quantity    Decimal @db.Decimal(18, 4)
  rate        Decimal @db.Decimal(18, 4)
  taxId       String?
  amount      Decimal @db.Decimal(18, 4)
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  item        Item?   @relation(fields: [itemId], references: [id])
}

model Quote {
  id                    String              @id @default(cuid())
  organizationId        String
  number                String // app code refers to this as quoteNumber
  referenceNumber       String?
  contactId             String
  status                QuoteStatus         @default(DRAFT)
  issueDate             DateTime
  expiryDate            DateTime?
  salespersonId         String?
  projectId             String?
  subject               String?
  currency              String              @default("INR")
  subTotal              Decimal             @default(0) @db.Decimal(18, 4)
  discountValue         Decimal             @default(0) @db.Decimal(18, 4)
  discountType          String              @default("percentage") // percentage | amount
  taxType               String? // TDS | TCS
  taxId                 String?
  taxAmount             Decimal             @default(0) @db.Decimal(18, 4)
  adjustmentLabel       String?             @default("Adjustment")
  adjustmentValue       Decimal             @default(0) @db.Decimal(18, 4)
  total                 Decimal             @default(0) @db.Decimal(18, 4)
  customerNotes         String?
  termsAndConditions    String?
  pdfTemplateId         String?
  sentAt                DateTime?
  acceptedAt            DateTime?
  declinedAt            DateTime?
  convertedInvoiceId    String?
  convertedSalesOrderId String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  deletedAt             DateTime?
  organization          Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact               Contact             @relation(fields: [contactId], references: [id])
  lineItems             QuoteLineItem[]
  attachments           QuoteAttachment[]
  reportingTags         QuoteReportingTag[]

  @@unique([organizationId, number])
  @@index([organizationId, status, deletedAt])
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
  INVOICED
}

model QuoteLineItem {
  id           String  @id @default(cuid())
  quoteId      String
  itemId       String?
  accountId    String? // M17a — per-line account override
  position     Int     @default(0)
  name         String
  description  String?
  hsnSacCode   String?
  quantity     Decimal @db.Decimal(18, 4)
  unit         String?
  rate         Decimal @db.Decimal(18, 4)
  discount     Decimal @default(0) @db.Decimal(18, 4)
  discountType String  @default("percentage")
  taxId        String?
  taxAmount    Decimal @default(0) @db.Decimal(18, 4)
  amount       Decimal @db.Decimal(18, 4)
  quote        Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

model QuoteAttachment {
  id        String   @id @default(cuid())
  quoteId   String
  fileName  String
  fileUrl   String
  fileSize  Int
  mimeType  String
  createdAt DateTime @default(now())
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

model QuoteReportingTag {
  id                   String @id @default(cuid())
  quoteId              String
  reportingTagOptionId String
  quote                Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

model SalesOrder {
  id                       String                 @id @default(cuid())
  organizationId           String
  number                   String // app code refers to this as salesOrderNumber
  referenceNumber          String?
  contactId                String
  status                   SalesOrderStatus       @default(DRAFT)
  orderDate                DateTime
  expectedShipmentDate     DateTime?
  paymentTermsId           String?
  deliveryMethodId         String?
  salespersonId            String?
  currency                 String                 @default("INR")
  subTotal                 Decimal                @default(0) @db.Decimal(18, 4)
  discountValue            Decimal                @default(0) @db.Decimal(18, 4)
  discountType             String                 @default("percentage")
  taxType                  String?
  taxId                    String?
  taxAmount                Decimal                @default(0) @db.Decimal(18, 4)
  adjustmentLabel          String?                @default("Adjustment")
