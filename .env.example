# PostgreSQL — use Vercel Postgres, Neon, or Supabase
DATABASE_URL="postgresql://user:password@host:5432/quikfinance?schema=public"
DIRECT_URL="postgresql://user:password@host:5432/quikfinance?schema=public"

# NextAuth
AUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Microsoft 365 / Entra ID OAuth (https://entra.microsoft.com → App registrations)
# Callback URL: <your-app>/api/auth/callback/microsoft-entra-id
# AUTH_MICROSOFT_TENANT_ID defaults to "common" (accepts work + personal MS accounts).
# Override for single-tenant deployments.
AUTH_MICROSOFT_ID=""
AUTH_MICROSOFT_SECRET=""
AUTH_MICROSOFT_TENANT_ID=""

# GitHub OAuth (https://github.com/settings/developers → New OAuth App)
# Callback URL: <your-app>/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Email (Resend — https://resend.com)
# Powers transactional email AND the magic-link (passwordless) sign-in flow.
# When RESEND_API_KEY + EMAIL_FROM are set, the /login page surfaces a
# "Sign in with email" field that sends a one-click sign-in link.
RESEND_API_KEY=""
EMAIL_FROM="Quikfinance <noreply@quikfinance.app>"

# Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=""

# UploadThing (optional file uploads)
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# Public app URL (used in referral links, emails)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Public app URL used by the Razorpay webhook URL displayed in setup modal.
# Falls back to NEXT_PUBLIC_APP_URL / NEXTAUTH_URL when unset.
APP_URL=""

# AES-256-GCM key encrypting Razorpay key secret + webhook secret at rest.
# Generate with: openssl rand -hex 32
RAZORPAY_KEK=""
